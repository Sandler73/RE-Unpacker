#!/usr/bin/env bash
# =============================================================================
# re-unpacker -- shell wrapper (Linux / macOS)
#
# SYNOPSIS
#   re-unpacker [OPTIONS] INPUT
#
# DESCRIPTION
#   Adds the bundled 'src/' directory to PYTHONPATH and runs
#   `python3 -m re_unpacker`. Use this when you haven't `pip install`-ed
#   the package and just want to run it straight from a clone on Kali
#   or any Linux distribution.
#
#   Cross-platform note (v0.4.0): two sibling wrappers ship for
#   Windows users:
#     - re-unpacker.ps1 -- PowerShell wrapper (preferred on Windows)
#     - re-unpacker.cmd -- cmd.exe shim for users without PowerShell
#   This bash wrapper is for Linux / macOS only.
#
# EXECUTION PARAMETERS
#   All arguments are forwarded verbatim to the Python entry point.
#   See `re-unpacker --help` for the full CLI surface.
#
# EXAMPLES
#   ./re-unpacker sample.deb
#   ./re-unpacker ./samples -o ./out -j 4
#   ./re-unpacker --tools-check
#
# NOTES
#   - Requires Python 3.10+. Kali's default /usr/bin/python3 suffices.
#   - Does not alter your environment beyond the child process.
#
# VERSION
#   0.4.8
# =============================================================================

set -euo pipefail

# Resolve the script's own directory so the wrapper works from any cwd.
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
SRC_DIR="${SCRIPT_DIR}/src"

if [[ ! -d "${SRC_DIR}/re_unpacker" ]]; then
    echo "error: cannot find package source at ${SRC_DIR}/re_unpacker" >&2
    exit 4
fi

# Prepend, don't overwrite, any user PYTHONPATH.
export PYTHONPATH="${SRC_DIR}${PYTHONPATH:+:${PYTHONPATH}}"

# Exec so signals (SIGINT from Ctrl-C, SIGTERM) reach Python cleanly.
exec python3 -m re_unpacker "$@"
